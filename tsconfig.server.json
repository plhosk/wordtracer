{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noEmit": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "./dist/server",
    "rootDir": "./src",
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src/server.ts", "src/game-engine.ts", "src/types.ts", "src/persistence.ts"],
  "exclude": ["src/main.ts", "src/styles.css"]
}